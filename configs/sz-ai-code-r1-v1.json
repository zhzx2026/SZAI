{
  "name": "SZ-AI-Code-R1/V1",
  "seed": 42,
  "dataset": {
    "path": "build/code-corpus/train.txt",
    "encoding": "utf-8",
    "seq_len": 128,
    "stride": 32,
    "val_ratio": 0.05
  },
  "model": {
    "embedding_dim": 128,
    "hidden_size": 256,
    "num_layers": 2,
    "dropout": 0.1
  },
  "training": {
    "batch_size": 16,
    "epochs": 2,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "grad_clip": 1.0
  },
  "generation": {
    "sample_prompt": "def solve(",
    "temperature": 0.8,
    "top_k": 24,
    "max_new_tokens": 240
  }
}
